<div class="container mt-4">
    
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="font-weight-bold text-dark"><i class="fas fa-users mr-2 text-primary"></i>Cartera de Clientes</h2>
            <p class="text-muted">Gestiona tus clientes y crea nuevas cotizaciones.</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex">
                <input type="text" id="searchInput" class="form-control mr-2 shadow-sm" placeholder="🔍 Buscar cliente por nombre..." style="border-radius: 20px;">
                <a href="/quotes/add" class="btn btn-success shadow-sm" style="border-radius: 20px; white-space: nowrap;">
                    <i class="fas fa-plus-circle mr-1"></i> Nuevo Cliente
                </a>
            </div>
        </div>
    </div>

    <hr>

    <div class="row" id="customersContainer">
        {{#each customers}}
            <div class="col-md-4 mb-4 customer-card"> <div class="card h-100 border-0 shadow-sm hover-shadow" style="border-radius: 15px; transition: transform 0.2s;">
                    
                    <div class="card-header bg-white border-0 pt-3 pb-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge badge-primary px-3 py-2" style="font-size: 0.85em; border-radius: 10px;">{{aliasCus}}</span>
                            <div class="dropdown">
                                <button class="btn btn-link text-muted p-0" type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <div class="dropdown-menu dropdown-menu-right">
                                    <a class="dropdown-item text-primary" href="/customers/edit/{{_id}}"><i class="fas fa-edit mr-2"></i>Editar</a>
                                    <form action="/customers/delete/{{_id}}?_method=DELETE" method="POST" class="d-inline">
                                        <button type="submit" class="dropdown-item text-danger" onclick="return confirm('¿Estás seguro de eliminar este cliente?');">
                                            <i class="fas fa-trash-alt mr-2"></i>Eliminar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-body">
                        <h4 class="card-title font-weight-bold text-dark nombreCus mb-3">{{nombreCus}}</h4>
                        
                        <div class="text-muted mb-2">
                            <i class="fas fa-user-tie mr-2 text-info" style="width: 20px; text-align: center;"></i> 
                            {{#if contactoCus}}{{contactoCus}}{{else}}<span class="font-italic text-black-50">Sin contacto</span>{{/if}}
                        </div>
                        
                        <div class="text-muted mb-3">
                            <i class="fas fa-phone-alt mr-2 text-success" style="width: 20px; text-align: center;"></i> 
                            {{#if telefonoCus}}{{telefonoCus}}{{else}}<span class="font-italic text-black-50">--</span>{{/if}}
                        </div>

                        <a href="/customers/{{_id}}/quotations" class="btn btn-outline-primary btn-block font-weight-bold shadow-sm mt-3" style="border-radius: 20px;">
                            <i class="fas fa-file-invoice mr-2"></i> Ver Cotizaciones
                        </a>
                    </div>
                </div>
            </div>
        {{else}}
            <div class="col-12 text-center mt-5">
                <div class="jumbotron bg-white shadow-sm border" style="border-radius: 20px;">
                    <img src="/img/logo_nav.png" alt="Logo" style="height: 60px; opacity: 0.5;" class="mb-3">
                    <h3 class="text-muted">No hay clientes registrados aún.</h3>
                    <p class="lead">Comienza agregando tu primer cliente para crear cotizaciones.</p>
                    <a href="/quotes/add" class="btn btn-primary btn-lg shadow mt-2" style="border-radius: 30px;">
                        <i class="fas fa-plus-circle mr-2"></i> Agregar Cliente
                    </a>
                </div>
            </div>
        {{/each}}
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>

<script>
    document.getElementById('searchInput').addEventListener('keyup', function() {
        const filter = this.value.toLowerCase();
        const customerCards = document.querySelectorAll('.customer-card');

        customerCards.forEach(card => {
            // Buscamos tanto por Nombre como por Alias
            const nombreCus = card.querySelector('.nombreCus').textContent.toLowerCase();
            const aliasCus = card.querySelector('.badge').textContent.toLowerCase();
            
            if (nombreCus.includes(filter) || aliasCus.includes(filter)) {
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
    });
</script>