<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Quotation</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    
    <script>
        function addDetail() {
            const detailsContainer = document.getElementById('detailsContainer');
            const detailIndex = detailsContainer.childElementCount; 
            const lineaNumero = detailIndex + 1;

            const detailTemplate = `
                <div class="detail mb-2 p-3 border rounded bg-light shadow-sm" id="detail-${detailIndex}">
                    <div class="form-row">
                        <div class="col-md-2">
                            <label class="mb-1">Linea:</label>
                            <input type="number" 
                                name="detalles[${detailIndex}][lineaQuo]" 
                                class="form-control form-control-sm text-center font-weight-bold" 
                                value="${lineaNumero}" 
                                readonly>
                        </div>

                        <input type="hidden" 
                            name="detalles[${detailIndex}][tipoQuo]" 
                            value="R">

                        <div class="col-md-2">
                            <label class="mb-1">Cantidad:</label>
                            <input type="number" 
                                name="detalles[${detailIndex}][cantidadQuo]" 
                                class="form-control form-control-sm" required>
                        </div>
                        <div class="col-md-6">
                            <label class="mb-1">Descripción:</label>
                            <textarea name="detalles[${detailIndex}][descripcionQuo]" 
                                    class="form-control form-control-sm" 
                                    rows="6" required></textarea>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="btn btn-danger btn-sm" onclick="removeDetail(${detailIndex})">Remove</button>
                        </div>
                    </div>
                    <hr>
                </div>
            `;

            detailsContainer.insertAdjacentHTML('beforeend', detailTemplate);
        }

        function removeDetail(index) {
            const detailElement = document.getElementById(`detail-${index}`);
            if (detailElement) {
                detailElement.remove();
                const detalles = document.querySelectorAll('#detailsContainer .detail');
                detalles.forEach((detalle, i) => {
                    const lineaInput = detalle.querySelector('input[name$="[lineaQuo]"]');
                    if (lineaInput) lineaInput.value = i + 1;
                });
            }
        }
    </script>
</head>
<body>
    <div class="container mt-4 mb-5">
        <h1>Nueva solicitud</h1>
        
        <form action="/customers/{{customerId}}/quotations" method="POST">
            
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Cabecera de la Cotización</h3>
                </div>
                <div class="card-body">
                    <div class="form-row">
                        <div class="form-group col-md-2">
                            <label for="fecha" class="mb-1 font-weight-bold">Fecha:</label>
                            <input type="date" id="fecha" name="fecha" class="form-control form-control-sm" required>
                        </div>
                        <div class="form-group col-md-2">
                            <label for="fechaVence" class="mb-1 font-weight-bold">Fecha Vence:</label>
                            <input type="date" id="fechaVence" name="fechaVence" class="form-control form-control-sm" required>
                        </div>
                        <div class="form-group col-md-8">
                            <label for="descripcionCorta" class="mb-1 font-weight-bold">Descripción Corta:</label>
                            <input type="text" id="descripcionCorta" name="descripcionCorta" class="form-control form-control-sm" required>
                        </div>
                    </div>
                </div>
            </div>
            
            <br>
            
            <div class="card shadow-sm border-secondary">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h3 class="mb-0 text-secondary">Detalles de la Cotización</h3>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="addDetail()">Add Detail</button>
                </div>
                
                <div class="card-body bg-info bg-light border-bottom p-3">
                    <label for="texto-cliente" class="text-dark font-weight-bold mb-1">
                        <i class="fas fa-robot text-info mr-1"></i> IA: Pegar solicitud del cliente para generar el detalle
                    </label>
                    <div class="input-group">
                        <textarea id="texto-cliente" class="form-control" rows="2" placeholder="Ej: Quiero 5000 impresiones de hojas membretadas, tamaño carta, refiladas..."></textarea>
                        <div class="input-group-append">
                            <button type="button" id="btn-interpretar" class="btn btn-info shadow-sm px-4">
                                <i class="fas fa-magic"></i> Interpretar
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card-body bg-white p-3" id="detailsContainer" style="max-height: 400px; overflow-y: auto;">
                    </div>
            </div>
            
            <br>
            
            <div class="form-group">
                <button class="btn btn-success btn-block btn-lg shadow-sm" type="submit">Create Quotation</button>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const detailsContainer = document.getElementById('detailsContainer');
            
            // Inicializar con una línea vacía al cargar la página
            if (detailsContainer.childElementCount === 0) {
                addDetail();
            }

            const btnInterpretar = document.getElementById('btn-interpretar');
            
            btnInterpretar.addEventListener('click', async () => {
                const texto = document.getElementById('texto-cliente').value;
                
                if (!texto.trim()) {
                    alert('Por favor, ingresa la solicitud en la caja de texto.');
                    return;
                }

                const textoOriginal = btnInterpretar.innerHTML;
                btnInterpretar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';
                btnInterpretar.disabled = true;

                try {
                    const response = await fetch('/api/interpretar-pedido', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ textoCliente: texto })
                    });

                    if (!response.ok) throw new Error('Error al conectar con el servidor de IA');
                    const datos = await response.json();

                    // Armamos la descripción técnica ordenada para el detalle
                    let descripcionArmada = `${datos.producto}\n`;
                    if (datos.tamano) descripcionArmada += `▶ Tamaño: ${datos.tamano}\n`;
                    if (datos.material) descripcionArmada += `▶ Material: ${datos.material}\n`;
                    if (datos.impresion) descripcionArmada += `▶ Impresión: ${datos.impresion}\n`;
                    if (datos.acabados && datos.acabados.length > 0) {
                        descripcionArmada += `▶ Acabados: ${datos.acabados.join(', ')}`;
                    }

                    // Obtenemos la última línea agregada
                    let ultimoDetalle = detailsContainer.lastElementChild;
                    let inputDescActual = ultimoDetalle ? ultimoDetalle.querySelector('textarea[name$="[descripcionQuo]"]') : null;
                    
                    // Si el último detalle ya tiene algo escrito, creamos una línea NUEVA automáticamente
                    if (!ultimoDetalle || (inputDescActual && inputDescActual.value.trim() !== "")) {
                        addDetail(); 
                        ultimoDetalle = detailsContainer.lastElementChild;
                    }
                    
                    // Inyectamos SÓLO en la línea de detalle seleccionada
                    const inputCantidad = ultimoDetalle.querySelector('input[name$="[cantidadQuo]"]');
                    const inputDescripcion = ultimoDetalle.querySelector('textarea[name$="[descripcionQuo]"]');
                    
                    if (inputCantidad && datos.cantidad) {
                        inputCantidad.value = datos.cantidad;
                    }
                    if (inputDescripcion) {
                        inputDescripcion.value = descripcionArmada.trim();
                    }

                    // Vaciamos la caja de IA
                    document.getElementById('texto-cliente').value = '';

                } catch (error) {
                    console.error("Error AI:", error);
                    alert('Hubo un problema al contactar con la Inteligencia Artificial.');
                } finally {
                    btnInterpretar.innerHTML = textoOriginal;
                    btnInterpretar.disabled = false;
                }
            });
        });
    </script>
</body>
</html>