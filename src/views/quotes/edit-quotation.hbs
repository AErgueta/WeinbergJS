<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Cotización</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    
    <style>
        /* Estilos personalizados */
        .form-control {
            border-radius: 10px;
            border: 1px solid #ced4da;
        }
        .form-control:focus {
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.15);
            border-color: #80bdff;
        }
        .detail-card {
            background-color: #f8f9fa;
            border-left: 5px solid #007bff;
            transition: all 0.3s ease;
        }
        .detail-card:hover {
            background-color: #fff;
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.10)!important;
            transform: translateY(-2px);
        }
        .btn-circle {
            width: 35px;
            height: 35px; 
            padding: 6px 0px;
            border-radius: 50%;
            text-align: center; 
            font-size: 12px; 
            line-height: 1.42857;
        }
        textarea.form-control {
            resize: vertical;
            min-height: 38px;
        }
    </style>

    <script>
        // --- LÓGICA JAVASCRIPT ---

        // 1. Redirigir a Calculadora
        function redirectToCalculator(detailIndex) {
            const quotationId = document.getElementById('quotationId').value;
            const customerId = document.getElementById('customerId').value;
            window.location.href = `/calculatorTres?quotationId=${quotationId}&customerId=${customerId}&detailIndex=${detailIndex}`;
        }

        // 2. Redirigir a Resumen de Costos
        function redirectToResumen(detailIndex) {
            const quotationId = document.getElementById('quotationId').value;
            const customerId = document.getElementById('customerId').value;
            window.location.href = `/calculatorResumen?quotationId=${quotationId}&customerId=${customerId}&detailIndex=${detailIndex}`;
        }

        document.addEventListener('DOMContentLoaded', function () {
            // Cargar datos originales
            const details = {{{json detalles}}} || {{{json quotation.detalles}}};
            renderDetails(details);

            // ==========================================
            // LOGICA DE INTELIGENCIA ARTIFICIAL (NUEVO)
            // ==========================================
            const btnInterpretar = document.getElementById('btn-interpretar');
            if(btnInterpretar) {
                btnInterpretar.addEventListener('click', async () => {
                    const texto = document.getElementById('texto-cliente').value;
                    const detailsContainer = document.getElementById('detailsContainer');
                    
                    if (!texto.trim()) {
                        alert('Por favor, ingresa la solicitud en la caja de texto.');
                        return;
                    }

                    const textoOriginal = btnInterpretar.innerHTML;
                    btnInterpretar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';
                    btnInterpretar.disabled = true;

                    try {
                        const response = await fetch('/api/interpretar-pedido', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ textoCliente: texto })
                        });

                        if (!response.ok) throw new Error('Error al conectar con el servidor de IA');
                        const datos = await response.json();

                        // Armamos la descripción
                        let descripcionArmada = `${datos.producto}\n`;
                        if (datos.tamano) descripcionArmada += `▶ Tamaño: ${datos.tamano}\n`;
                        if (datos.material) descripcionArmada += `▶ Material: ${datos.material}\n`;
                        if (datos.impresion) descripcionArmada += `▶ Impresión: ${datos.impresion}\n`;
                        if (datos.acabados && datos.acabados.length > 0) {
                            descripcionArmada += `▶ Acabados: ${datos.acabados.join(', ')}`;
                        }

                        let ultimoDetalle = detailsContainer.lastElementChild;
                        let inputDescActual = ultimoDetalle ? ultimoDetalle.querySelector('textarea[name$="[descripcionQuo]"]') : null;
                        
                        // Si no hay detalles, o el último ya tiene descripción escrita, crea uno nuevo
                        if (!ultimoDetalle || (inputDescActual && inputDescActual.value.trim() !== "")) {
                            addDetail(); 
                            ultimoDetalle = detailsContainer.lastElementChild;
                        }
                        
                        const inputCantidad = ultimoDetalle.querySelector('input[name$="[cantidadQuo]"]');
                        const inputDescripcion = ultimoDetalle.querySelector('textarea[name$="[descripcionQuo]"]');
                        
                        if (inputCantidad && datos.cantidad) {
                            inputCantidad.value = datos.cantidad;
                        }
                        if (inputDescripcion) {
                            inputDescripcion.value = descripcionArmada.trim();
                        }

                        // Limpiar la caja de IA
                        document.getElementById('texto-cliente').value = '';

                    } catch (error) {
                        console.error("Error AI:", error);
                        alert('Hubo un problema al contactar con la Inteligencia Artificial.');
                    } finally {
                        btnInterpretar.innerHTML = textoOriginal;
                        btnInterpretar.disabled = false;
                    }
                });
            }
        });

        function renderDetails(details) {
            const container = document.getElementById('detailsContainer');
            container.innerHTML = ''; 
            details.forEach((detail, index) => {
                const row = createDetailRow(detail, index);
                container.appendChild(row);
            });
        }

        function addDetail() {
            const container = document.getElementById('detailsContainer');
            const index = container.children.length;
            // Nueva fila vacía (tieneCalculos inicia en false)
            const newDetail = { lineaQuo: index + 1, tipoQuo: 'P', cantidadQuo: 0, descripcionQuo: '', tieneCalculos: false };
            const row = createDetailRow(newDetail, index);
            container.appendChild(row);
        }

        function removeDetail(button) {
            const row = button.closest('.detail-row');
            row.remove();
        }

        // --- FUNCIÓN DE DISEÑO ---
        function createDetailRow(detail, index) {
            const div = document.createElement('div');
            div.className = 'card mb-3 border-0 shadow-sm detail-card detail-row'; 
            div.style.borderRadius = "15px";
            
            // Evaluamos si 'tieneCalculos' es "truthy"
            const hasCalculations = detail.tieneCalculos ? true : false;
            const resumenBtnClass = hasCalculations ? 'btn-outline-info' : 'btn-outline-secondary disabled';
            const resumenBtnAttr = hasCalculations ? '' : 'disabled title="Primero debes realizar el cálculo (botón verde)"';
            
            div.innerHTML = `
                <div class="card-body py-3">
                    <div class="row align-items-center">
                        <div class="col-md-1 col-2 mb-2 mb-md-0">
                            <label class="small text-muted font-weight-bold">#</label>
                            <input type="number" name="detalles[${index}][lineaQuo]" class="form-control form-control-sm text-center font-weight-bold" value="${detail.lineaQuo}" readonly style="background-color: #e9ecef;">
                        </div>

                        <div class="col-md-2 col-4 mb-2 mb-md-0">
                            <label class="small text-muted font-weight-bold">Tipo</label>
                            <select name="detalles[${index}][tipoQuo]" class="form-control form-control-sm">
                                <option value="P" ${detail.tipoQuo === 'P' ? 'selected' : ''}>Producto</option>
                                <option value="R" ${detail.tipoQuo === 'R' ? 'selected' : ''}>Repuesto</option>
                            </select>
                        </div>

                        <div class="col-md-2 col-6 mb-2 mb-md-0">
                            <label class="small text-muted font-weight-bold">Cantidad</label>
                            <input type="number" name="detalles[${index}][cantidadQuo]" class="form-control form-control-sm" value="${detail.cantidadQuo}" required>
                        </div>

                        <div class="col-md-4 col-12 mb-2 mb-md-0">
                            <label class="small text-muted font-weight-bold">Descripción del Ítem</label>
                            <textarea name="detalles[${index}][descripcionQuo]" class="form-control form-control-sm" rows="3" required placeholder="Descripción del trabajo...">${detail.descripcionQuo || ''}</textarea>
                        </div>

                        <div class="col-md-3 col-12 d-flex justify-content-end align-items-end mt-2 mt-md-0">
                            <button type="button" class="btn btn-outline-success shadow-sm mr-1" onclick="redirectToCalculator(${index})" title="Calcular Precio" style="border-radius: 20px;">
                                <i class="fas fa-calculator"></i>
                            </button>

                            <button type="button" class="btn ${resumenBtnClass} shadow-sm mr-1" onclick="redirectToResumen(${index})" ${resumenBtnAttr} style="border-radius: 20px;">
                                <i class="fas fa-file-invoice-dollar"></i>
                            </button>

                            <button type="button" class="btn btn-outline-danger btn-circle shadow-sm" onclick="removeDetail(this)" title="Eliminar fila">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </div>
                    </div>
                </div>
            `;
            return div;
        }
    </script>
</head>
<body class="bg-light">

    <div class="container mt-4 mb-5">
        
        <form action="/customers/{{customer._id}}/quotations/edit/{{quotation._id}}" method="POST">
            <input type="hidden" name="_method" value="PUT">
            
            <input type="hidden" id="quotationId" value="{{quotation._id}}">
            <input type="hidden" id="customerId" value="{{customer._id}}">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
                <div class="mb-3 mb-md-0">
                    <a href="/customers/{{customer._id}}/quotations" class="text-muted text-decoration-none mb-2 d-inline-block">
                        <i class="fas fa-arrow-left mr-1"></i> Cancelar y Volver
                    </a>
                    <h2 class="font-weight-bold text-dark">
                        <i class="fas fa-edit text-primary mr-2"></i>Editar Cotización
                    </h2>
                </div>
                <div>
                    <button type="submit" class="btn btn-success btn-lg shadow" style="border-radius: 30px; padding-left: 30px; padding-right: 30px;">
                        <i class="fas fa-save mr-2"></i> Guardar Cambios
                    </button>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="text-primary font-weight-bold"><i class="far fa-calendar-alt mr-2"></i>Cabecera de la Cotización</h5>
                </div>
                <div class="card-body">
                    <div class="form-row">
                        <div class="form-group col-md-3">
                            <label for="fecha" class="font-weight-bold text-dark">Fecha:</label>
                            <input type="date" id="fecha" name="fecha" class="form-control" required value="{{formatDateLocal quotation.fecha}}">
                        </div>
                        <div class="form-group col-md-3">
                            <label for="fechaVence" class="font-weight-bold text-dark">Fecha Vence:</label>
                            <input type="date" id="fechaVence" name="fechaVence" class="form-control" required value="{{formatDateLocal quotation.fechaVence}}">
                        </div>
                        <div class="form-group col-md-6">
                            <label for="descripcionCorta" class="font-weight-bold text-dark">Descripción Corta:</label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-light border-right-0" style="border-radius: 10px 0 0 10px;"><i class="fas fa-tag text-muted"></i></span>
                                </div>
                                <input type="text" id="descripcionCorta" name="descripcionCorta" class="form-control border-left-0" style="border-radius: 0 10px 10px 0;" required value="{{quotation.descripcionCorta}}">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="font-weight-bold text-dark"><i class="fas fa-list-ul mr-2 text-info"></i>Detalles de la Cotización</h4>
                <button type="button" class="btn btn-outline-primary shadow-sm" onclick="addDetail()" style="border-radius: 20px;">
                    <i class="fas fa-plus mr-1"></i> Línea Manual
                </button>
            </div>

            <div class="card shadow-sm mb-4 border-info" style="border-radius: 15px;">
                <div class="card-body bg-light" style="border-radius: 15px;">
                    <label for="texto-cliente" class="text-dark font-weight-bold mb-2">
                        <i class="fas fa-robot text-info mr-1"></i> Asistente de IA: Pega un nuevo requerimiento del cliente
                    </label>
                    <div class="input-group">
                        <textarea id="texto-cliente" class="form-control" rows="2" style="border-radius: 10px 0 0 10px;" placeholder="Ej: Además, cotízame 2000 tarjetas de presentación plastificadas..."></textarea>
                        <div class="input-group-append">
                            <button type="button" id="btn-interpretar" class="btn btn-info shadow-sm px-4" style="border-radius: 0 10px 10px 0;">
                                <i class="fas fa-magic mr-1"></i> Interpretar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="detailsContainer" class="mb-4">
                </div>

            <hr>
            <div class="row mt-4 mb-5">
                <div class="col-12 text-center">
                    <button type="submit" class="btn btn-success btn-lg shadow px-5" style="border-radius: 30px; transform: scale(1.1);">
                        <i class="fas fa-save mr-2"></i> Guardar Cambios
                    </button>
                </div>
            </div>

            <div class="py-4"></div>

        </form>
    </div>

</body>
</html>